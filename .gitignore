*
# Allow GitHub related files
!.gitignore
!.gitmodules
!.github
!.github/**/*
!README.md
!CONTRIBUTING.md
!examples/
!examples/TB_Example.vhd
!examples/Example.vhd
# Allow Doxygen file
!Doxyfile
# Allow script files
!scripts/
!scripts/**/*.tcl
!scripts/**/*.sh
!scripts/**/*.py
# Allow hardware related files
!hw
!hw/**/
!hw/*.xsa
# Allow software related files
!sw
!sw/*_app
!sw/*_app/**
sw/**/*.*
!sw/*_app/src/**/*.c
!sw/*_app/src/**/*.h
!sw/*_app/src/**/*.ld
sw/*_app/src/platform.h
sw/*_app/src/platform.c
# Docs for DAPI
!docs/
!docs/**/
docs/**/*.*
!docs/**/*.tex
!docs/**/*.pdf
!docs/**/*.md
!docs/**/*.drawio
!docs/**/*.svg
# Vivado logs
vivado.jou
vivado.log
.DS_Store
